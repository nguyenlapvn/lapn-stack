#!/usr/bin/env bash
# bin/lapn — LapN CLI router.
# Convention: lapn <module:action> [--flags]. No arguments → interactive menu.
set -euo pipefail

# --- Find LAPN_HOME (the code directory), even when invoked through a symlink ---
_resolve_home() {
  local src="${BASH_SOURCE[0]}" dir
  while [[ -h "$src" ]]; do
    dir="$(cd -P "$(dirname "$src")" >/dev/null 2>&1 && pwd)"
    src="$(readlink "$src")"
    [[ "$src" != /* ]] && src="$dir/$src"
  done
  dir="$(cd -P "$(dirname "$src")" >/dev/null 2>&1 && pwd)"
  # bin/ -> repo root
  dirname "$dir"
}

LAPN_HOME="$(_resolve_home)"
export LAPN_HOME

# shellcheck source=../lib/core.sh
source "$LAPN_HOME/lib/core.sh"
core_bootstrap

# --- Interactive menu ---

# Clear the screen (if available), skip if unsupported.
lapn_clear() { command -v clear >/dev/null 2>&1 && clear || printf '\n'; }

# Pause so the user can read the result before returning to the menu.
lapn_pause() {
  printf '\n%sPress Enter to return to the menu...%s' "$C_DIM" "$C_RESET"
  read -r _ || true
}

# Submenu of a module — loops until the user chooses "Back".
lapn_submenu() {
  local chosen="$1"
  # shellcheck disable=SC2206
  local cmds=(${LAPN_MODULE_CMDS[$chosen]})
  local choice j
  while true; do
    lapn_clear
    printf '%s%sLapN%s › %s%s%s\n\n' "$C_BOLD" "$C_BLUE" "$C_RESET" "$C_BOLD" "$chosen" "$C_RESET"
    for j in "${!cmds[@]}"; do
      printf '  %s) %s\n' "$((j + 1))" "${cmds[$j]}"
    done
    printf '  0) ← Back to main menu\n'

    read -r -p "→ " choice || return 0
    [[ "$choice" == "0" || -z "$choice" ]] && return 0
    if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#cmds[@]} )); then
      printf '\n'
      # Run in a subshell: a command's die/exit does not kill the menu; errors do not propagate to set -e.
      ( core_dispatch "${cmds[$((choice - 1))]}" ) || log_warn "Command finished with an error (see the message above)."
      lapn_pause
    else
      log_warn "Invalid choice."
      lapn_pause
    fi
  done
}

# Main menu — loops until the user chooses "Exit".
lapn_menu() {
  local modules=() name
  while IFS= read -r name; do
    modules+=("$name")
  done < <(
    for name in "${!LAPN_MODULE_ORDER[@]}"; do
      printf '%s\t%s\n' "${LAPN_MODULE_ORDER[$name]}" "$name"
    done | sort -n | cut -f2-
  )

  local choice i menu_names=()
  while true; do
    lapn_clear
    printf '%s%sLapN%s — Lightweight App Platform for Node.js\n' "$C_BOLD" "$C_BLUE" "$C_RESET"
    printf '%sChoose a feature group:%s\n\n' "$C_DIM" "$C_RESET"

    menu_names=(); i=1
    for name in "${modules[@]}"; do
      [[ -z "${LAPN_MODULE_CMDS[$name]:-}" ]] && continue
      printf '  %s) %s\n' "$i" "$name"
      menu_names+=("$name")
      ((i++))
    done
    printf '  0) Exit\n'

    read -r -p "→ " choice || return 0
    [[ "$choice" == "0" || -z "$choice" ]] && { printf 'Goodbye.\n'; return 0; }
    if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#menu_names[@]} )); then
      lapn_submenu "${menu_names[$((choice - 1))]}"
    else
      log_warn "Invalid choice."
      lapn_pause
    fi
  done
}

# --- Help ---
lapn_help() {
  printf 'LapN — manage Node.js websites on a VPS.\n\n'
  printf 'Usage:\n'
  printf '  lapn                      open the interactive menu\n'
  printf '  lapn <module:action> ...  run a command directly\n'
  printf '  lapn help                 this help\n\n'
  printf 'Available commands:\n'
  local name c
  while IFS= read -r name; do
    [[ -z "${LAPN_MODULE_CMDS[$name]:-}" ]] && continue
    printf '  %s%s%s\n' "$C_BOLD" "$name" "$C_RESET"
    for c in ${LAPN_MODULE_CMDS[$name]}; do
      printf '    lapn %s\n' "$c"
    done
  done < <(
    for n in "${!LAPN_MODULE_ORDER[@]}"; do
      printf '%s\t%s\n' "${LAPN_MODULE_ORDER[$n]}" "$n"
    done | sort -n | cut -f2-
  )
}

main() {
  if [[ $# -eq 0 ]]; then
    if [[ "${LAPN_INTERACTIVE:-0}" == "1" ]]; then
      lapn_menu
    else
      lapn_help
    fi
    return 0
  fi
  case "$1" in
    help|-h|--help) lapn_help ;;
    version|-v|--version) printf 'lapn %s\n' "$(cat "$LAPN_HOME/VERSION" 2>/dev/null || echo '0.1.0')" ;;
    *) core_dispatch "$@" ;;
  esac
}

main "$@"
